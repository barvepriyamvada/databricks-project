{
  "datasets": [
    {
      "name": "d98d330a",
      "displayName": "Global Carbon Emission Locations Dataset",
      "queryLines": [
        "select\n",
        "latitude,\n",
        "longitude,\n",
        "`GHG emissions mtons CO2e` as Emissions\n",
        "from emissions.default.emissions_data"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "dbe41e9d",
      "displayName": "Emissions per person",
      "queryLines": [
        "select\n",
        "    county_state_name,\n",
        "    population,\n",
        "    CAST(\n",
        "      REPLACE(`GHG emissions mtons CO2e`, ',', '') \n",
        "      AS DOUBLE\n",
        "      ) / nullif(\n",
        "        CAST(\n",
        "          REPLACE(`Population`, ',', '') \n",
        "          AS DOUBLE\n",
        "        ), 0\n",
        "      ) as Emissions_per_person\n",
        "from emissions.default.emissions_data\n",
        "ORDER BY emissions_per_person DESC"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "4652157a",
      "displayName": "Total Emissions per State",
      "queryLines": [
        "select\n",
        "    state_abbr,\n",
        "    SUM(CAST(\n",
        "      REPLACE(`GHG emissions mtons CO2e`, ',', '') \n",
        "      AS DOUBLE\n",
        "      )) as Total_Emissions\n",
        "from emissions.default.emissions_data\n",
        "group by state_abbr\n",
        "ORDER BY Total_Emissions DESC\n",
        "limit 10 "
      ]
    },
    {
      "name": "c1b1cb45",
      "displayName": "County Shaming",
      "queryLines": [
        "select\n",
        "    county_state_name,\n",
        "    population,\n",
        "    CAST(\n",
        "      REPLACE(`GHG emissions mtons CO2e`, ',', '') \n",
        "      AS DOUBLE\n",
        "      ) as Total_Emissions\n",
        "from emissions_data\n",
        "ORDER BY Total_Emissions DESC\n",
        "limit 10 "
      ],
      "catalog": "emissions",
      "schema": "default"
    }
  ],
